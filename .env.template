# =================================================================
# PyClaw (OpenClaw-Lite) 系統環境變數設定
# =================================================================

# --- LLM API 設定 ---
# 填入您的 Google Gemini API 金鑰 (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# 預設使用的 Gemini 模型
# 推薦使用 gemini-1.5-flash (速度快、成本低) 或 gemini-1.5-pro (邏輯能力強)
GEMINI_MODEL=gemini-1.5-flash

# --- 伺服器設定 ---
HOST=127.0.0.1
PORT=8000
BASE_URL=http://127.0.0.1:8000


# --- 系統路徑設定 ---
# SQLite 資料庫路徑
DATABASE_PATH=pyclaw.db

# Agent 可以操作的工作區目錄 (預設為當前目錄下的 agent_workspace)
AGENT_WORKSPACE=./agent_workspace

# --- Google Drive 雲端硬碟備份設定 ---
# 填入您的 Google Drive OAuth 2.0 用戶端 JSON 金鑰檔案路徑 (例如 google_drive_credentials.json)
GOOGLE_DRIVE_CREDENTIALS_PATH=google_drive_credentials.json
# 登入授權成功後，程式自動產生的憑證快取路徑 (自動建立，免手動調整)
GOOGLE_DRIVE_TOKEN_PATH=google_drive_token.json

